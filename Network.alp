								<Code><![CDATA[double a=0;
double b=kolAbonent;
numAbonent = 5;
 // Розыгрыш номера получателя сообщения
 a=uniform();
for (int i=1; i<(kolAbonent+1); i++)
 {if (a<=((1/kolAbonent)*b))
 agent.numAbPol=i;
 b=b-1;}
agent.timeOtpr=time();
agent.numAbOtpr=numAbonent;
]]></Code>
							</Value>
