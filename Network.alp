								<Code><![CDATA[double a=0;
double b=kolAbonent;
 // Розыгрыш номера получателя сообщения
 a=uniform();
for (int i=1; i<(kolAbonent+1); i++)
 {if (a<=((1/kolAbonent)*b))
 entity.numAbPol=i;
 b=b-1;}
entity.timeOtpr=time();
entity.numAbOtpr=numAbonent;]]></Code>
